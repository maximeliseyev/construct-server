# =============================================================================
# Construct Server — Lite mode environment template
# =============================================================================
# Copy to .env.lite and fill in required values:
#   cp ops/.env.lite.example .env.lite
#
# Run from REPO ROOT:
#   docker compose -f ops/docker-compose.lite.yml --env-file .env.lite up -d
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Your server domain (used in JWT issuer, federation, deep links)
INSTANCE_DOMAIN=example.com

# PostgreSQL password — pick a strong random string
POSTGRES_PASSWORD=change_me_strong_password

# JWT signing secret — minimum 32 chars, high entropy
# Generate: openssl rand -base64 48
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48

# Docker image tag (use a specific release tag, not latest, for production)
IMAGE_TAG=latest

# ── Optional ──────────────────────────────────────────────────────────────────

# PostgreSQL credentials (defaults shown)
POSTGRES_USER=construct
POSTGRES_DB=construct

# Gateway port exposed to host (put nginx/caddy on top for TLS)
GATEWAY_PORT=3000

# Message retention period (days)
MESSAGE_TTL_DAYS=7

# Log level: error | warn | info | debug | trace
RUST_LOG=info,sqlx=warn

# ── APNs Push Notifications (optional — iOS push) ─────────────────────────────
# Leave APNS_ENABLED=false if you don't need iOS push notifications.
APNS_ENABLED=false
APNS_ENVIRONMENT=sandbox
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# Generate: openssl rand -base64 32
APNS_DEVICE_TOKEN_ENCRYPTION_KEY=

# ── ICE / obfs4 Transport (optional — censorship circumvention) ───────────────
# Enable to accept obfs4-obfuscated connections alongside plain traffic.
# Generate key: run gateway once with ICE_ENABLED=true, copy key from logs.
ICE_ENABLED=false
ICE_PORT=9443
ICE_SERVER_KEY=
